{
  "name": "aug-agent-vscode",
  "displayName": "Aug Agent",
  "publisher": "aug-agent",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.102.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:augAgent.openChat",
    "onChatParticipant:aug-agent.main"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "augAgent.openChat",
        "title": "Aug Agent: Open Chat"
      },
      {
        "command": "augAgent.signInDeepSeek",
        "title": "Aug Agent: Sign in with DeepSeek"
      }
    ],
    "configuration": {
      "title": "Aug Agent",
      "properties": {
        "augAgent.mode": {
          "type": "string",
          "enum": ["auto", "quick", "deep"],
          "default": "auto",
          "description": "Retrieval behavior per turn."
        },
        "augAgent.defaultProvider": {
          "type": "string",
          "default": "deepseek",
          "description": "Default provider in model picker."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@aug-agent/core": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/vscode": "^1.102.0",
    "typescript": "^5.9.2"
  }
}
